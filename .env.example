# Database
DATABASE_URL=postgres://user:password@host:port/dbname

# Stripe
STRIPE_SECRET_KEY=sk_test_...

# Firebase Admin
# This should be the JSON service account key as a single-line string
FIREBASE_SERVICE_ACCOUNT=

# Security
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# App URL (used for email verification links)
APP_URL=https://your-app-name.railway.app

# MT5 Bridge (Optional)
MT5_BRIDGE_URL=
MT5_BRIDGE_SECRET=

# AI (Optional)
GEMINI_API_KEY=

# Client-side (Public) - Must be prefixed with VITE_
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ExchangeRate-API Caching Solution
EXCHANGERATE_API_KEY=
EXCHANGERATE_UPDATE_INTERVAL_MINUTES=30
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=
